{
  "name": "eva-speak",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch backend/server.js",
    "dev:web": "vite --config frontend/vite.config.js",
    "build": "vite build --config frontend/vite.config.js",
    "start": "node backend/server.js",
    "test:api": "node --test backend/*.test.js"
  },
  "dependencies": {
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "multer": "^2.0.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.0",
    "vite": "^7.3.6"
  }
}
